# Neon Postgres connection string (same instance as golf-betting-tool)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Flask session secret key
FLASK_SECRET_KEY=change-me-to-a-random-string

# Admin password hash (generate with: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))")
ADMIN_PASSWORD_HASH=
